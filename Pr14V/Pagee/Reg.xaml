<Page x:Class="Pr14V.Page.Reg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14V.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Reg">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Регистрация / Вход" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20" />

            <TextBlock Text="Логин:" Margin="0,5" />
            <TextBox x:Name="TBoxLogin" Height="30" VerticalContentAlignment="Center" />

            <TextBlock Text="Пароль:" Margin="0,10,0,5" />
            <PasswordBox x:Name="PBoxPass" Height="30" VerticalContentAlignment="Center" />

            <Button x:Name="BtnEntry" Content="Войти / Зарегистрироваться" Height="35" Margin="0,20" 
            Click="BtnEntry_Click" Background="#007ACC" Foreground="White" />

            <Button x:Name="BtnBack" Content="Назад" Click="BtnBack_Click" Background="Transparent" BorderThickness="0" />
        </StackPanel>

    </Grid>
</Page>
