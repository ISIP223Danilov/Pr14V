<Page x:Class="Pr14V.Pagee.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14V.Pagee"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Инфо об аккаунте -->
                <RowDefinition Height="*" />
                <!-- Список билетов -->
                <RowDefinition Height="Auto" />
                <!-- Кнопка назад -->
            </Grid.RowDefinitions>

            <!-- Информация об аккаунте -->
            <Border Grid.Row="0" Background="#F9F9F9" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Личный кабинет" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />
                    <TextBlock x:Name="TxtFullName" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="TxtEmail" Foreground="Gray" />
                    <TextBlock x:Name="TxtUsername" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <!-- Список всех билетов -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Ваши билеты:" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />
                <ListBox x:Name="LBoxUserTickets" Height="300" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" Margin="5" Padding="10" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <!-- Привязка через навигационные свойства -->
                                        <TextBlock Text="{Binding Screenings.Movies.Title}" FontWeight="Bold" FontSize="16" />
                                        <TextBlock Text="{Binding Screenings.ShowDateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" />
                                        <TextBlock Text="{Binding Screenings.Halls.Name, StringFormat='Зал: {0}'}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SeatNumber, StringFormat='Место: {0}'}" 
                                       VerticalAlignment="Center" FontSize="18" Foreground="#007ACC" FontWeight="Bold" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Кнопки управления -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Выйти из аккаунта" Click="BtnExit_Click" Margin="0,0,10,0" Width="150" Height="30" />
                <Button Content="На главную" Click="BtnBack_Click" Width="120" Height="30" Background="#007ACC" Foreground="White" />
            </StackPanel>
        </Grid>

    </Grid>
</Page>
