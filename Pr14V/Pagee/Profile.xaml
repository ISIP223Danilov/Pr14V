<Page x:Class="Pr14V.Pagee.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14V.Pagee"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Информация об аккаунте -->
        <Border Grid.Row="0" Background="#F9F9F9" Padding="15" CornerRadius="10" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Личный кабинет" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Пользователь: " FontSize="18" />
                    <TextBlock x:Name="TxtUserDisplay" FontSize="18" FontWeight="SemiBold" Foreground="#007ACC" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Список билетов -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Ваши купленные билеты:" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />
            <ListBox x:Name="LBoxUserTickets" Height="300" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,5" Padding="15" CornerRadius="8" Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <!-- Проверь: если в базе таблица Movies, то тут Screenings.Movies.Title -->
                                    <TextBlock Text="{Binding Screenings.Movies.Title}" FontWeight="Bold" FontSize="18" Foreground="#333" />
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="{Binding Screenings.ScreeningDate, StringFormat='dd.MM.yyyy'}" Margin="0,0,10,0" />
                                        <TextBlock Text="{Binding Screenings.StartTime}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Screenings.Halls.Name, StringFormat='Зал: {0}'}" Foreground="Gray" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SeatNumber, StringFormat='Место: {0}'}" FontSize="18" Foreground="#007ACC" FontWeight="Bold" />
                                    <!-- Если цены нет в билете, можно привязать к цене сеанса: Screenings.Price -->
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0} руб.'}" FontSize="14" Margin="0,5,0,0" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Выйти из аккаунта" Click="BtnExit_Click" Margin="0,0,10,0" Width="150" Height="35" Background="#FFE0E0" />
            <Button Content="На главную" Click="BtnBack_Click" Width="120" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" />
        </StackPanel>

    </Grid>
</Page>
