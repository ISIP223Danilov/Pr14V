<Page x:Class="Pr14V.Page.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14V.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid Background="#F0F0F0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
                <TextBox x:Name="TBoxSearch" Width="250" Height="28" Margin="5" 
                 VerticalContentAlignment="Center" TextChanged="TBoxSearch_TextChanged" />

                <ComboBox x:Name="ComboSort" Width="180" Height="28" Margin="10,5" 
                  SelectionChanged="ComboSort_SelectionChanged">
                    <ComboBoxItem Content="Без сортировки" IsSelected="True" />
                    <ComboBoxItem Content="По названию (А-Я)" />
                    <ComboBoxItem Content="По рейтингу (сначала высокие)" />
                </ComboBox>

                <Button x:Name="BtnProfile" Content="Личный кабинет" Width="140" Height="28" 
                Margin="50,5,5,5" Click="BtnProfile_Click" Background="#007ACC" Foreground="White" />
            </StackPanel>

          
            <ListBox x:Name="LBoxMovies" Grid.Row="1" BorderThickness="0" Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
             MouseDoubleClick="LBoxMovies_MouseDoubleClick">

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" Margin="5" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Width="200" Height="380" Margin="10" 
                        CornerRadius="8" BorderBrush="#DDD" BorderThickness="1">
                            <StackPanel>
                                <Image Source="{Binding Photo}" Height="250" Stretch="UniformToFill" Margin="5" />
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" 
                                   Margin="8,5,8,2" TextWrapping="Wrap" Height="40" />
                                <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}'}" 
                                   Foreground="Orange" FontWeight="Bold" Margin="8,0" />
                                <Grid Margin="8,10">
                                    <TextBlock Text="{Binding AgeLimit, StringFormat='{}{0}+'}" 
           HorizontalAlignment="Left" Foreground="Red" FontWeight="SemiBold" />

                                    <TextBlock Text="{Binding StartDate, StringFormat='{}{0:dd.MM.yyyy}'}" 
           HorizontalAlignment="Right" Foreground="Gray" />

                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</Page>
