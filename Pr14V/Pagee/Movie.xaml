<Page x:Class="Pr14V.Page.MoviePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr14V.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Movie">

    <Grid>
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image x:Name="ImgPoster" Stretch="Uniform" VerticalAlignment="Top" />

            <StackPanel Grid.Column="1" Margin="20,0">
                <TextBlock x:Name="TxtTitle" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
                <TextBlock x:Name="TxtRating" FontSize="18" Foreground="Orange" Margin="0,5" />
                <TextBlock x:Name="TxtDesc" Margin="0,10" TextWrapping="Wrap" FontSize="14" />

                <TextBlock Text="Расписание сеансов:" FontSize="20" Margin="0,20,0,10" FontWeight="SemiBold" />
                <ListBox x:Name="LBoxScreenings" MouseDoubleClick="LBoxScreenings_MouseDoubleClick" Height="135">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:dd.MM HH:mm}'}" Width="100" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Halls.Name}" Width="150" />
                                    <TextBlock Text="{Binding Halls.Classification}" Foreground="Gray" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
